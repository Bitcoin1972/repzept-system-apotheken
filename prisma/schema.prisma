generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PrescriptionType {
  RED
  GREEN
  ACUTE
  REPEAT
  DISCHARGE
  OTHER
}

enum RequestStatus {
  DRAFT
  ANSWERED
  CLOSED
  APPROVED
  RELEASED
  DISPENSED
  COMPLETED
}

enum SignatureStatus {
  DRAFT
  PENDING
  SIGNED
}

enum PharmacyReleaseStatus {
  NOT_RELEASED
  PRE_RELEASED
  STANDARD_FLOW_COMPLETED
}

enum RecipeFormType {
  GKV_MUSTER16
  GREEN
  PRIVATE
  BTM
  T_REZEPT
}

enum CatalogSource {
  PMS_CATALOG
  EXTERNAL_API
}

enum PmsType {
  GENERIC_PMS
  INTERNAL_CATALOG_API
  EXTERNAL_E_PRESCRIPTION
}

enum ConnectionVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum RequestDistributionStatus {
  RELEASED
  VIEWED
  IN_PROGRESS
  DISPENSED
  BLOCKED_DUPLICATE
}

enum SupportRole {
  PRACTICE
  PHARMACY
}

enum SupportComponent {
  PMS_CONNECTOR
  CATALOG_API
  PHARMACY_CONNECTION
  STRIPE_SYNC
  RELEASE_FLOW
  SUPPORT_UI
}

enum SupportSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuthRole {
  PRACTICE_ADMIN
  DOCTOR_USER
  PHARMACY_USER
}

enum PharmacyPlan {
  SMALL
  STANDARD
  NETWORK
}

enum SubscriptionStatus {
  INACTIVE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum InvoiceStatus {
  DRAFT
  PREPARED
  ISSUED
  PAID
  VOID
}

enum SwexEntityType {
  PRACTICE
  PHARMACY
}

model Practice {
  id                   String                      @id @default(cuid())
  name                 String
  street               String?
  city                 String?
  postalCode           String?
  latitude             Float?
  longitude            Float?
  pickupNotificationEmail String?
  trialStartsAt        DateTime?
  trialEndsAt          DateTime?
  pmsType              PmsType                     @default(GENERIC_PMS)
  pmsSystemLabel       String?
  pmsApiBaseUrl        String?
  pmsApiKeyMasked      String?
  catalogSource        CatalogSource               @default(PMS_CATALOG)
  catalogProviderLabel String?
  catalogApiBaseUrl    String?
  catalogApiKeyMasked  String?
  stripeCustomerRef    String?
  stripeSubscriptionRef String?
  stripeCheckoutUrl    String?
  swexTenantRef        String?
  swexCustomerRef      String?
  renderWorkspaceSlug  String?
  renderServiceName    String?
  copyToOwnRenderOnActivation Boolean              @default(false)
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  doctors              DoctorUser[]
  requests             Request[]
  pharmacyConnections  PracticePharmacyConnection[]
  supportTickets       SupportTicket[]
  stripePayments       StripePaymentRecord[]
  swexCustomers        SwexCustomerLink[]
  swexOrders           SwexOrderSync[]
  authUsers            AuthUser[]
}

model DoctorUser {
  id               String    @id @default(cuid())
  practiceId       String
  name             String
  email            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  practice         Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  releasedRequests Request[] @relation("ReleasedByDoctor")
  authUsers        AuthUser[]
}

model PharmacyAccount {
  id                 String                      @id @default(cuid())
  name               String
  email              String?
  contactPhone       String?
  street             String?
  city               String?
  postalCode         String?
  latitude           Float?
  longitude          Float?
  verificationCode   String                      @unique
  stripeCustomerRef  String?
  billingEmail       String?
  swexTenantRef      String?
  swexCustomerRef    String?
  plan               PharmacyPlan                @default(SMALL)
  monthlyPriceCents  Int                         @default(9900)
  subscriptionStatus SubscriptionStatus          @default(INACTIVE)
  stripeSubscriptionRef String?
  stripeLatestInvoiceRef String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  practiceConnections PracticePharmacyConnection[]
  requestDistributions RequestDistribution[]
  dispenseLogs       DispenseLog[]
  supportTickets     SupportTicket[]
  stripePayments     StripePaymentRecord[]
  swexCustomers      SwexCustomerLink[]
  swexOrders         SwexOrderSync[]
  authUsers          AuthUser[]
  usageSnapshots     PharmacyUsageSnapshot[]
  invoices           PharmacyInvoice[]
}

model AuthUser {
  id                String           @id @default(cuid())
  email             String           @unique
  passwordHash      String
  role              AuthRole
  displayName       String
  practiceId        String?
  doctorUserId      String?
  pharmacyAccountId String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  practice          Practice?        @relation(fields: [practiceId], references: [id], onDelete: SetNull)
  doctorUser        DoctorUser?      @relation(fields: [doctorUserId], references: [id], onDelete: SetNull)
  pharmacyAccount   PharmacyAccount? @relation(fields: [pharmacyAccountId], references: [id], onDelete: SetNull)
  sessions          Session[]

  @@index([practiceId])
  @@index([doctorUserId])
  @@index([pharmacyAccountId])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PracticePharmacyConnection {
  id                       String                        @id @default(cuid())
  practiceId               String
  pharmacyId               String
  pharmacyVerificationCode String
  verificationStatus       ConnectionVerificationStatus  @default(PENDING)
  verificationReason       String?
  connectedAt              DateTime?
  verifiedByAiAt           DateTime?
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt
  practice                 Practice                      @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  pharmacy                 PharmacyAccount               @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  requestDistributions     RequestDistribution[]
  supportTickets           SupportTicket[]

  @@unique([practiceId, pharmacyId])
}

model Request {
  id                    String                @id @default(cuid())
  practiceId            String?
  releasedByDoctorId    String?
  doctorName            String?
  insuranceProvider     String?
  patientReference      String?
  patientEmail          String?
  demoMode              Boolean               @default(false)
  prescriptionType      PrescriptionType      @default(ACUTE)
  recipeFormType        RecipeFormType        @default(GKV_MUSTER16)
  status                RequestStatus         @default(DRAFT)
  signatureStatus       SignatureStatus       @default(DRAFT)
  pharmacyReleaseStatus PharmacyReleaseStatus @default(NOT_RELEASED)
  normalFlowPending     Boolean               @default(false)
  releasedToPharmacyAt  DateTime?
  signedAt              DateTime?
  issuedAt              DateTime?
  summary               String?
  transcription         String?
  outputText            String?
  medicationName        String?
  productName           String?
  manufacturer          String?
  dosage                String?
  form                  String?
  pzn                   String?
  quantity              String?
  signedBy              String?
  medicationStrength    String?
  medicationPzn         String?
  medicationSource      String?
  clinicalPayload       Json?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  practice              Practice?             @relation(fields: [practiceId], references: [id], onDelete: SetNull)
  releasedByDoctor      DoctorUser?           @relation("ReleasedByDoctor", fields: [releasedByDoctorId], references: [id], onDelete: SetNull)
  responses             Response[]
  requestDistributions  RequestDistribution[]
  dispenseLogs          DispenseLog[]
  supportTickets        SupportTicket[]
  pharmacyResponses     PharmacyResponse[]
}

model Response {
  id        String   @id @default(cuid())
  requestId String
  kind      String
  payload   Json
  createdAt DateTime @default(now())
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model PharmacyResponse {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  requestId      String
  pharmacyName   String
  responseStatus String
  message        String
  request        Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model RequestDistribution {
  id                 String                    @id @default(cuid())
  requestId          String
  pharmacyId         String
  connectionId       String
  status             RequestDistributionStatus @default(RELEASED)
  releasedAt         DateTime                  @default(now())
  viewedAt           DateTime?
  processingStartedAt DateTime?
  dispensedAt        DateTime?
  blockedAt          DateTime?
  viewedByUserId     String?
  processingByUserId String?
  dispensedByUserId  String?
  note               String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  request            Request                   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  pharmacy           PharmacyAccount           @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  connection         PracticePharmacyConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  dispenseLogs       DispenseLog[]
}

model DispenseLog {
  id             String               @id @default(cuid())
  requestId      String
  pharmacyId     String?
  distributionId String?
  eventType      String
  eventNote      String?
  actorUserId    String?
  actorEmail     String?
  actorRole      AuthRole?
  createdAt      DateTime             @default(now())
  request        Request              @relation(fields: [requestId], references: [id], onDelete: Cascade)
  pharmacy       PharmacyAccount?     @relation(fields: [pharmacyId], references: [id], onDelete: SetNull)
  distribution   RequestDistribution? @relation(fields: [distributionId], references: [id], onDelete: SetNull)
}

model SupportTicket {
  id                 String                    @id @default(cuid())
  practiceId         String?
  pharmacyId         String?
  requestId          String?
  connectionId       String?
  swexProjectId      String
  externalRef        String                    @unique
  language           String                    @default("de")
  role               SupportRole
  component          SupportComponent
  severity           SupportSeverity          @default(MEDIUM)
  category           String
  technicalSignature String
  summary            String
  internalMessage    String
  internalContext    Json?
  swexPayload        Json
  swexTicketRef      String
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  practice           Practice?                @relation(fields: [practiceId], references: [id], onDelete: SetNull)
  pharmacy           PharmacyAccount?         @relation(fields: [pharmacyId], references: [id], onDelete: SetNull)
  request            Request?                 @relation(fields: [requestId], references: [id], onDelete: SetNull)
  connection         PracticePharmacyConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
}

model StripePaymentRecord {
  id                    String           @id @default(cuid())
  practiceId            String?
  pharmacyId            String?
  stripeCustomerId      String?
  stripePaymentIntentId String           @unique
  stripeInvoiceId       String?
  customerName          String?
  amount                Int
  currency              String
  status                String
  description           String?
  paidAt                DateTime?
  failedAt              DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  practice              Practice?        @relation(fields: [practiceId], references: [id], onDelete: SetNull)
  pharmacy              PharmacyAccount? @relation(fields: [pharmacyId], references: [id], onDelete: SetNull)
}

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  eventType     String
  objectId      String?
  status        String   @default("processed")
  errorMessage  String?
  payload       Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SwexCustomerLink {
  id              String          @id @default(cuid())
  entityType      SwexEntityType
  practiceId      String?
  pharmacyId      String?
  stripeCustomerId String
  swexProjectId   String
  swexCustomerRef String
  externalRef     String          @unique
  customerName    String?
  customerEmail   String?
  phone           String?
  company         String?
  address         Json?
  lastPayload     Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  practice        Practice?       @relation(fields: [practiceId], references: [id], onDelete: SetNull)
  pharmacy        PharmacyAccount? @relation(fields: [pharmacyId], references: [id], onDelete: SetNull)
  orders          SwexOrderSync[]

  @@unique([swexProjectId, stripeCustomerId])
}

model SwexOrderSync {
  id                   String           @id @default(cuid())
  customerLinkId       String?
  entityType           SwexEntityType
  practiceId           String?
  pharmacyId           String?
  swexProjectId        String
  swexCustomerRef      String?
  swexSaleRef          String
  externalRef          String           @unique
  stripeEventId        String?
  stripeCheckoutSessionId String?
  stripeInvoiceId      String?
  stripePaymentIntentId String?
  stripeSubscriptionId String?
  productName          String
  amountCents          Int
  currency             String           @default("EUR")
  billingCycle         String
  paymentStatus        String
  payload              Json?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  customerLink         SwexCustomerLink? @relation(fields: [customerLinkId], references: [id], onDelete: SetNull)
  practice             Practice?        @relation(fields: [practiceId], references: [id], onDelete: SetNull)
  pharmacy             PharmacyAccount? @relation(fields: [pharmacyId], references: [id], onDelete: SetNull)

  @@unique([swexProjectId, stripeCheckoutSessionId])
  @@unique([swexProjectId, stripeInvoiceId])
  @@unique([swexProjectId, stripePaymentIntentId])
}

model PharmacyUsageSnapshot {
  id                String          @id @default(cuid())
  pharmacyId        String
  monthStart        DateTime
  releasedCount     Int             @default(0)
  dispensedCount    Int             @default(0)
  activeConnections Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  pharmacy          PharmacyAccount @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  invoices          PharmacyInvoice[]

  @@unique([pharmacyId, monthStart])
}

model PharmacyInvoice {
  id                    String               @id @default(cuid())
  pharmacyId            String
  usageSnapshotId       String?
  monthStart            DateTime
  monthEnd              DateTime
  plan                  PharmacyPlan
  amountCents           Int
  currency              String               @default("eur")
  status                InvoiceStatus        @default(DRAFT)
  stripeInvoiceId       String?
  stripeHostedInvoiceUrl String?
  stripeCustomerId      String?
  lineItemDescription   String
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  pharmacy              PharmacyAccount      @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  usageSnapshot         PharmacyUsageSnapshot? @relation(fields: [usageSnapshotId], references: [id], onDelete: SetNull)

  @@unique([pharmacyId, monthStart])
}
